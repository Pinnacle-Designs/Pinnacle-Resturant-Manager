}

model VendorInvoice {
  id             String              @id @default(cuid())
  locationId     String
  location       Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  vendor         String
  amount         Float
  category       String
  invoiceDate    DateTime            @default(now())
  priceChangePct Float               @default(0)
  poId           String?
  po             VendorPurchaseOrder? @relation(fields: [poId], references: [id], onDelete: SetNull)
  receiptId      String?
  receipt        GoodsReceipt?       @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  invoiceNumber  String?
  imageUrl       String?
  matchStatus    String              @default("PENDING")
  matchNotes     String?
  accountingSyncLocked Boolean @default(false)
  paymentHoldReason  String?
  paidAt             DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now()) @updatedAt

  lines   VendorInvoiceLine[]
  credits VendorCredit[]

  @@index([locationId, matchStatus])
}

model VendorInvoiceLine {
  id              String         @id @default(cuid())
  invoiceId       String
  invoice         VendorInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  sku             String?
  description     String
  qty             Float
  unit            String
  unitPrice       Float
  lineTotal       Float
  catchWeightBilled   Float?
  catchWeightUnit     String?

  @@index([invoiceId])
}

model VendorPriceHistory {
  id            String   @id @default(cuid())
  locationId    String
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  vendor        String
  itemName      String
  category      String
  unitPrice     Float
  unit          String   @default("lbs")
  effectiveDate DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([locationId, vendor, itemName])
  @@index([locationId, effectiveDate])
}

model InventoryWaste {
  id              String         @id @default(cuid())
  locationId      String
  location        Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  itemName        String
  quantity        Float
  unit            String
  cost            Float
  reason          String
  countSessionId  String?
  lotId           String?
  wasteCategory     String?
  recordedByStaffId String?
  recordedByStaff   StaffMember? @relation(fields: [recordedByStaffId], references: [id], onDelete: SetNull)
  shiftId           String?
  shift             Shift?       @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  date            DateTime       @default(now())
  createdAt       DateTime       @default(now())
}

model ExternalFactor {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  date        DateTime
  factorType  String
  description String
  impactPct   Float    @default(0)
  createdAt   DateTime @default(now())
}

model TrainingSettings {
  id                 String   @id @default(cuid())
  locationId         String   @unique
  location           Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  expirationWarnDays Int      @default(30)
  updatedAt          DateTime @updatedAt
}

model StaffCertification {
  id                String   @id @default(cuid())
  locationId        String
  location          Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  staffMemberId     String
  staffMember       StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  certType          String
  issuer            String?
  certificateNumber String?
  issuedAt          DateTime?
  expiresAt         DateTime?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([locationId, expiresAt])
  @@index([staffMemberId])
}

model TrainingModule {
  id               String             @id @default(cuid())
  locationId       String
  location         Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  moduleKey        String
  title            String
  kind             TrainingModuleKind @default(COMPLIANCE)
  summary          String
  content          String
  estimatedMinutes Int                @default(15)
  required         Boolean            @default(true)
  renewalMonths    Int?
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  completions      TrainingCompletion[]

  @@unique([locationId, moduleKey])
}

model TrainingCompletion {
  id            String         @id @default(cuid())
  locationId    String
  location      Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  moduleId      String
  module        TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  staffMemberId String
  staffMember   StaffMember    @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  completedAt   DateTime       @default(now())
  score         Int?
  signatureName String?
  expiresAt     DateTime?
  createdAt     DateTime       @default(now())

  @@index([staffMemberId, moduleId])
  @@index([locationId, expiresAt])
}

model ComplianceSettings {
  id                       String   @id @default(cuid())
  locationId               String   @unique
  location                 Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  minorBlockScheduling     Boolean  @default(true)
  minorSchoolNightEndHour  Int      @default(22)
  minorSchoolNightDays     String   @default("0,1,2,3,4")
  minorMaxWeeklyHoursSchool Float   @default(18)
  minorMaxDailyHoursSchool  Float   @default(6)
  schoolCalendarActive     Boolean  @default(true)
  /// Block time-clock punches when minor laws would be violated
  minorBlockTimeClock      Boolean  @default(true)
  /// SMS manager when minor is within this many minutes of curfew
  minorAlertMinutesBefore  Int      @default(30)
  /// Phone for compliance SMS (E.164); falls back to location phone
  managerAlertPhone        String?
  /// Require declared cash tips before tipped employees clock out
  requireTipDeclaration    Boolean  @default(true)
  updatedAt                DateTime @updatedAt
}

model IncidentReport {
  id              String           @id @default(cuid())
  locationId      String
  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  reportedAt      DateTime         @default(now())
  incidentType    IncidentType
  category        String
  description     String
  staffMemberId   String?
  staffMember     StaffMember?     @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  guestName       String?
  severity        IncidentSeverity @default(MEDIUM)
  oshaRecordable  Boolean          @default(false)
  actionTaken     String?
  witnessNotes    String?
  status          IncidentStatus   @default(OPEN)
  reportedByName  String?
  closedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([locationId, reportedAt])
  @@index([locationId, status])
}

model ShiftFeedback {
  id            String            @id @default(cuid())
  locationId    String
  location      Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  staffMemberId String
  staffMember   StaffMember       @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  shiftId       String?
  shift         Shift?            @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  authorUserId  String?
  authorName    String
  kind          ShiftFeedbackKind @default(NOTE)
  content       String
  createdAt     DateTime          @default(now())

  @@index([staffMemberId, createdAt])
  @@index([locationId, createdAt])
  @@index([shiftId])
}

model LogBookEntry {
  id              String          @id @default(cuid())
  locationId      String
  location        Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  logDate         DateTime
  authorUserId    String?
  authorName      String
  category        LogBookCategory @default(GENERAL)
  title           String?
  content         String
  /// Lowercased text for SQLite search — content, title, author, staff names
  searchText      String
  salesTotal      Float?
  guestCount      Int?
  laborHours      Float?
  laborCost       Float?
  staffingNote    String?
  maintenanceNote String?
  pinned          Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  mentions        LogBookMention[]

  @@index([locationId, logDate])
  @@index([locationId, createdAt])
  @@index([locationId, category])
}

model LogBookMention {
  id            String        @id @default(cuid())
  entryId       String
  entry         LogBookEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  staffMemberId String?
  staffMember   StaffMember?  @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  mentionLabel  String

  @@index([staffMemberId])
  @@index([entryId])
}

model ModifierGroup {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  categories  String?
  menuItemId  String?
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  required    Boolean  @default(false)
  minSelect   Int      @default(1)
  maxSelect   Int      @default(1)
  sortOrder   Int      @default(0)
  layout      String   @default("STANDARD")
  options     ModifierOption[]

  @@index([locationId, menuItemId])
}

model ModifierOption {
  id         String        @id @default(cuid())
  groupId    String
  group      ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name       String
  priceDelta Float         @default(0)
  sortOrder  Int           @default(0)
  isDefault  Boolean       @default(false)
  kitchenStationId String?
  kitchenStation   KitchenStation? @relation(fields: [kitchenStationId], references: [id], onDelete: SetNull)
  fractionCoverage String?
}

model PosCategoryStyle {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  category   String
  color      String
  icon       String?

  @@unique([locationId, category])
}

enum MenuScheduleMode {
  SHOW_CATEGORIES
  HIDE_CATEGORIES
  HAPPY_HOUR
}

model MenuScheduleRule {
  id              String           @id @default(cuid())
  locationId      String
  location        Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name            String
  mode            MenuScheduleMode
  categories      String
  daysOfWeek      String           @default("0,1,2,3,4,5,6")
  startTime       String
  endTime         String
  priceMultiplier Float            @default(1)
  active          Boolean          @default(true)
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([locationId, active])
}

model ReportTemplate {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  reportId    String
  name        String
  description String?
  /// JSON ReportConfig — columns, filters, sort, branding, rowLimit
  configJson  String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locationId, reportId])
}
