generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PhotoCategory {
  MENU_ITEM
  INVENTORY
  STAFF
  FACILITY
  RECEIPT
  FOOD_PREP
  MARKETING
  MAINTENANCE
  OTHER
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  DEBIT
  MOBILE
  GIFT_CARD
  OTHER
}

enum CheckStatus {
  OPEN
  PRINTED
  PARTIALLY_PAID
  PAID
  CLOSED
  NEEDS_TIP
  REFUND_VOID_NEEDED
}

enum InsightSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InsightCategory {
  INVENTORY
  STAFFING
  FINANCE
  OPERATIONS
  MENU
  CUSTOMER
  FACILITY
  GENERAL
}

enum AppRole {
  OWNER
  MANAGER
  SERVER
  KITCHEN
  HOST
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  PRO
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  SNAPCHAT
  X
  YOUTUBE
  LINKEDIN
  PINTEREST
}

enum SocialPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  PARTIAL
  FAILED
}

enum PublishStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
}

enum PaymentProviderKind {
  MANUAL
  STRIPE
  SQUARE
}

enum PaymentProviderPurpose {
  SUBSCRIPTION
  POS
}

enum AccountingProvider {
  QUICKBOOKS
  XERO
  SAGE
}

enum VendorEdiProvider {
  SYSCO
  US_FOODS
  GORDON_FOOD_SERVICE
}

enum TipPoolMode {
  INDIVIDUAL
  FULL_POOL
  POINTS
  ROLE_WEIGHTED
}

enum PayrollRunStatus {
  DRAFT
  FINALIZED
  PAID
}

enum HolidayDenominatorMode {
  FIXED_DIVISOR
  DAYS_WORKED
  ANNUAL_PERCENTAGE
}

enum EmbeddedPayrollProvider {
  NONE
  GUSTO
  WAGEPOINT
  PAPAYA_GLOBAL
}

enum EwaAdvanceStatus {
  PENDING
  PAID
  DEDUCTED
  CANCELLED
}

enum ShiftSwapKind {
  SWAP
  BID
  DROP
}

enum ShiftSwapStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum ApplicationStatus {
  NEW
  SCREENING
  INTERVIEW_SCHEDULED
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

enum RehireStatus {
  UNKNOWN
  YES
  NO
  MAYBE
}

enum ApplicationSource {
  TEXT_APPLY
  WEB
  WALK_IN
  REFERRAL
}

enum SmsDirection {
  INBOUND
  OUTBOUND
}

enum OnboardingPacketStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
}

enum OnboardingDocType {
  I9
  W4
  DIRECT_DEPOSIT
}

enum TrainingModuleKind {
  COMPLIANCE
  SAFETY
  CERTIFICATION
}

enum CertAlertLevel {
  OK
  EXPIRING
  EXPIRED
  MISSING
}

enum IncidentType {
  WORKPLACE_INJURY
  GUEST_INCIDENT
  NEAR_MISS
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  CLOSED
}

enum ShiftFeedbackKind {
  NOTE
  SHOUT_OUT
  COACHING
}

enum ReservationProvider {
  OPENTABLE
  RESY
  TOCK
  YELP
}

enum ReservationStatus {
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum LogBookCategory {
  GENERAL
  SALES
  STAFFING
  MAINTENANCE
  STAFF
  GUEST
  INVENTORY
  SAFETY
  OPERATIONS
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String?
  role         AppRole
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  permissionOverride UserPermissionOverride?
  isPlatformAdmin Boolean @default(false)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  webAuthnCredentials WebAuthnCredential[]
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique
  publicKey    String
  counter      Int      @default(0)
  deviceLabel  String?
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

model Location {
  id            String   @id @default(cuid())
  name          String
  address       String?
  phone         String?
  seatCount     Int      @default(40)
  squareFootage Float    @default(2000)
  plan          SubscriptionPlan @default(STARTER)
  autopayEnabled Boolean  @default(false)
  billingEmail   String?
  paymentBrand   String?
  paymentLast4   String?
  paymentExpMonth Int?
  paymentExpYear  Int?
  nextBillingDate DateTime?
  /// Subscription agreement acceptance (required before checkout / autopay)
  subscriptionTermsAcceptedAt DateTime?
  subscriptionTermsVersion    String?
  subscriptionTermsPlan       SubscriptionPlan?
  subscriptionTermsAcceptedById String?
  setupComplete Boolean  @default(true)
  onboardingStep Int    @default(0)
  latitude       Float?
  longitude      Float?
  /// Postal / ZIP code — drives geocoding, holidays, weather, and local time
  postalCode     String?
  city           String?
  stateProvince  String?
  countryCode    String   @default("US")
  /// IANA timezone e.g. America/Chicago — synced from coordinates
  timezone       String?
  /// ISO 4217 currency — synced from country/postal (e.g. USD, GBP, CAD)
  currencyCode   String   @default("USD")
  /// imperial (US) or metric — synced from country/postal
  measurementSystem String @default("imperial")
  /// us | uk | metric — volume standard for pints, gallons, fl oz
  volumeStandard   String @default("us")
  /// BCP 47 locale for number/date formatting (e.g. en-US, en-GB)
  locale         String   @default("en-US")
  geoFenceRadiusM Int     @default(150)
  geoClockInRequired Boolean @default(true)
  punchPhotoRequired Boolean @default(true)
  punchVerificationMode String @default("PHOTO_OR_BIOMETRIC")
  earlyClockInBufferMins Int @default(15)
  forgottenClockOutGraceMins Int @default(30)
  blockUnscheduledPunch Boolean @default(false)
  targetLaborPct Float   @default(30)
  mealBreakMinutes Int   @default(30)
  restBreakMinutes Int   @default(10)
  /// Hours on clock before a meal break is legally required (e.g. 5 in CA)
  mealBreakRequiredAfterHours Float @default(5)
  /// Alert managers this many minutes before meal break is due
  mealBreakAlertMinutes     Int     @default(15)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  menuItems        MenuItem[]
  inventoryItems   InventoryItem[]
  staffMembers     StaffMember[]
  tables           Table[]
  orders           Order[]
  expenses         Expense[]
  photos           Photo[]
  businessInsights BusinessInsight[]
  activityLogs     ActivityLog[]
  shifts           Shift[]
  users            User[]
  socialAccounts   SocialAccount[]
  socialPosts      SocialPost[]
  websiteConnection WebsiteConnection?
  marketingCampaigns MarketingCampaign[]
  guestReviews     GuestReview[]
  vendorInvoices   VendorInvoice[]
  inventoryWaste   InventoryWaste[]
  vendorPriceHistory VendorPriceHistory[]
  externalFactors  ExternalFactor[]
  rolePermissionSets RolePermissionSet[]
  userPermissionOverrides UserPermissionOverride[]
  paymentProviderConnections PaymentProviderConnection[]
  payrollSettings      PayrollSettings?
  holidayPayRule       HolidayPayRule?
  tipPoolRuns          TipPoolRun[]
  payPeriods           PayPeriod[]
  ewaAdvances          EwaAdvance[]
  timeEntries          TimeEntry[]
  shiftSwapRequests    ShiftSwapRequest[]
  hiringSettings       HiringSettings?
  jobPostings          JobPosting[]
  applicants           Applicant[]
  applications         Application[]
  smsMessages          SmsMessage[]
  onboardingPackets    OnboardingPacket[]
  trainingSettings       TrainingSettings?
  staffCertifications  StaffCertification[]
  trainingModules      TrainingModule[]
  trainingCompletions  TrainingCompletion[]
  complianceSettings   ComplianceSettings?
  incidentReports      IncidentReport[]
  shiftFeedback        ShiftFeedback[]
  modifierGroups       ModifierGroup[]
  posCategoryStyles    PosCategoryStyle[]
  menuScheduleRules    MenuScheduleRule[]
  menuChannelConfigs   MenuChannelConfig[]
  kitchenStations      KitchenStation[]
  menuRevision         Int      @default(0)
  floorPlanWidth       Int      @default(900)
  floorPlanHeight      Int      @default(600)
  /// JSON array of dining zones: { id, name, x, y, width, height, color }
  floorPlanSections    String?
  integrationSettings  IntegrationSettings?
  reservationConnections ReservationConnection[]
  tableReservations    TableReservation[]
  logBookEntries       LogBookEntry[]
  accountingConnections AccountingConnection[]
  accountingJournalEntries AccountingJournalEntry[]
  vendorEdiConnections VendorEdiConnection[]
  vendorCatalogItems   VendorCatalogItem[]
  vendorPurchaseOrders VendorPurchaseOrder[]
  goodsReceipts        GoodsReceipt[]
  vendorCredits        VendorCredit[]
  storageZones         StorageZone[]
  inventoryLots        InventoryLot[]
  countSessions        InventoryCountSession[]
  reportTemplates      ReportTemplate[]
}

model KitchenStation {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  outputKind  String   @default("KDS")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menuItems        MenuItem[]
  comboComponents  MenuComboComponent[]
  modifierOptions  ModifierOption[]
  orderItems       OrderItem[]

  @@unique([locationId, slug])
  @@index([locationId])
}

model MenuComboComponent {
  id                String          @id @default(cuid())
  comboItemId       String
  comboItem         MenuItem        @relation("ComboParent", fields: [comboItemId], references: [id], onDelete: Cascade)
  componentItemId   String
  componentItem     MenuItem        @relation("ComboChild", fields: [componentItemId], references: [id], onDelete: Cascade)
  quantity          Int             @default(1)
  kitchenStationId  String?
  kitchenStation    KitchenStation? @relation(fields: [kitchenStationId], references: [id], onDelete: SetNull)
  sortOrder         Int             @default(0)

  @@index([comboItemId])
}

/// Per-channel menu publishing — markup %, sync status, third-party store IDs.
model MenuChannelConfig {
  id              String   @id @default(cuid())
  locationId      String
  location        Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  channel         String
  enabled         Boolean  @default(true)
  priceMarkupPct  Float    @default(0)
  externalStoreId String?
  lastSyncedAt    DateTime?
  lastSyncStatus  String?
  lastSyncMessage String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([locationId, channel])
  @@index([locationId])
}

model PaymentProviderConnection {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  provider    PaymentProviderKind
  purpose     PaymentProviderPurpose
  accountId   String?
  externalRef String?
  credential  String?
  status      String   @default("connected")
  metadata    String?
  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([locationId, purpose])
}

/// Real-time POS → inventory sync settings (recipe depletion on kitchen fire).
model IntegrationSettings {
  id                 String   @id @default(cuid())
  locationId         String   @unique
  location           Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  posSyncEnabled     Boolean  @default(true)
  lastPosSyncAt      DateTime?
  posDepletionsToday Int      @default(0)
  updatedAt          DateTime @updatedAt
}

model AccountingConnection {
  id                String             @id @default(cuid())
  locationId        String
  location          Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  provider          AccountingProvider
  connected         Boolean            @default(false)
  companyName       String?
  externalCompanyId String?
  autoSyncEnabled   Boolean            @default(true)
  lastSyncAt        DateTime?
  entriesSynced     Int                @default(0)
  lastSyncStatus    String?
  lastSyncMessage   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([locationId, provider])
}

model AccountingJournalEntry {
  id          String             @id @default(cuid())
  locationId  String
  location    Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  provider    AccountingProvider
  entryType   String
  reference   String
  description String
  debit       Float              @default(0)
  credit      Float              @default(0)
  accountCode String?
  sourceId    String?
  syncedAt    DateTime           @default(now())
}

model VendorEdiConnection {
  id                String            @id @default(cuid())
  locationId        String
  location          Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  provider          VendorEdiProvider
  connected         Boolean           @default(false)
  accountNumber     String?
  warehouseCode     String?
  catalogItemsCount Int               @default(0)
  lastCatalogSyncAt DateTime?
  lastOrderAt       DateTime?
  lastSyncStatus    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([locationId, provider])
}

model VendorCatalogItem {
  id              String            @id @default(cuid())
  locationId      String
  location        Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  provider        VendorEdiProvider
  sku             String
  name            String
  unit            String
  packSize        String?
  unitPrice       Float
  inStock         Boolean           @default(true)
  leadTimeDays    Int               @default(1)
  inventoryItemId String?
  inventoryItem   InventoryItem?    @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  updatedAt       DateTime          @updatedAt

  @@unique([locationId, provider, sku])
}

model VendorPurchaseOrder {
  id          String             @id @default(cuid())
  locationId  String
  location    Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  provider    VendorEdiProvider?
  vendor      String?
  poNumber    String?
  status      String             @default("DRAFT")
  source      String             @default("MANUAL")
  lineCount   Int
  totalAmount Float
  linesJson   String?
  expectedAt  DateTime?
  matchStatus String             @default("PENDING")
  submittedAt DateTime           @default(now())
  updatedAt   DateTime           @default(now()) @updatedAt

  lines    PurchaseOrderLine[]
  receipts GoodsReceipt[]
  invoices VendorInvoice[]

  @@index([locationId, status])
}

model PurchaseOrderLine {
  id              String              @id @default(cuid())
  poId            String
  po              VendorPurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem?      @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  sku             String?
  description     String
  qtyOrdered      Float
  qtyReceived     Float               @default(0)
  unit            String
  unitPrice       Float
  lineTotal       Float

  receiptLines GoodsReceiptLine[]

  @@index([poId])
}

model GoodsReceipt {
  id         String              @id @default(cuid())
  locationId String
  location   Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  poId       String?
  po         VendorPurchaseOrder? @relation(fields: [poId], references: [id], onDelete: SetNull)
  vendor     String
  receivedAt DateTime            @default(now())
  receivedBy String?
  notes      String?
  createdAt  DateTime            @default(now())

  lines    GoodsReceiptLine[]
  invoices VendorInvoice[]

  @@index([locationId, receivedAt])
}

model GoodsReceiptLine {
  id              String             @id @default(cuid())
  receiptId       String
  receipt         GoodsReceipt       @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  poLineId        String?
  poLine          PurchaseOrderLine? @relation(fields: [poLineId], references: [id], onDelete: SetNull)
  inventoryItemId String?
  inventoryItem   InventoryItem?     @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  description     String
  qtyReceived     Float
  unit            String
  unitCost        Float
  catchWeightReceived Float?
  catchWeightBilled   Float?
  catchWeightUnit     String?
  isSubstitution      Boolean  @default(false)
  orderedDescription  String?

  @@index([receiptId])
}

model VendorCredit {
  id           String         @id @default(cuid())
  locationId   String
  location     Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  vendor       String
  amount       Float
  reason       String
  status       String         @default("OPEN")
  category     String?
  creditMemoNo String?
  invoiceId    String?
  invoice      VendorInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  itemsJson    String?
  photoUrl     String?
  reportedBy   String?
  repEmail     String?
  emailSentAt  DateTime?
  emailStatus  String?
  accountingLocked Boolean    @default(false)
  createdAt    DateTime       @default(now())
  resolvedAt   DateTime?

  @@index([locationId, status])
  @@index([invoiceId, status])
}

model RolePermissionSet {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  role        AppRole
  permissions String
  updatedAt   DateTime @updatedAt

  @@unique([locationId, role])
}

model UserPermissionOverride {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions String
  updatedAt   DateTime @updatedAt
}

model MenuItem {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  category    String
  salesCategory String   @default("FOOD")
  recipeCost  Float    @default(0)
  recipeCostUpdatedAt DateTime?
  allergens     String?
  nutritionJson String?
  available   Boolean  @default(true)
  stockCount  Int?
  eightySixedAt DateTime?
  imageUrl    String?
  posColor    String?
  posGridIndex Int?
  kitchenStationId String?
  kitchenStation   KitchenStation? @relation(fields: [kitchenStationId], references: [id], onDelete: SetNull)
  defaultCourse    String          @default("MAIN")
  isCombo          Boolean         @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
  modifierGroups ModifierGroup[]
  comboComponents MenuComboComponent[] @relation("ComboParent")
  comboMemberships MenuComboComponent[] @relation("ComboChild")
  recipeLines        MenuRecipeLine[]
  recipeComponents   MenuRecipeComponent[] @relation("RecipeParent")
  usedInRecipes      MenuRecipeComponent[] @relation("RecipeComponent")
}

/// Ingredient build — theoretical food cost and inventory depletion per plate sold.
model MenuRecipeLine {
  id              String        @id @default(cuid())
  menuItemId      String
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantity        Float
  sortOrder       Int           @default(0)

  @@unique([menuItemId, inventoryItemId])
  @@index([menuItemId])
}

/// Sub-recipe — include another menu item's full recipe (ingredients roll up for cost & depletion).
model MenuRecipeComponent {
  id                  String   @id @default(cuid())
  parentMenuItemId    String
  parentMenuItem      MenuItem @relation("RecipeParent", fields: [parentMenuItemId], references: [id], onDelete: Cascade)
  componentMenuItemId String
  componentMenuItem   MenuItem @relation("RecipeComponent", fields: [componentMenuItemId], references: [id], onDelete: Cascade)
  quantity            Float
  sortOrder           Int      @default(0)

  @@unique([parentMenuItemId, componentMenuItemId])
  @@index([parentMenuItemId])
}

model InventoryItem {
  id            String   @id @default(cuid())
  locationId    String
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name          String
  barcode       String?
  quantity      Float
  unit          String
  minQuantity   Float    @default(0)
  costPerUnit   Float    @default(0)
  previousCostPerUnit Float?
  portionSize   Float?
  yieldPct      Float    @default(100)
  supplier      String?
  storageZoneId String?
  storageZone   StorageZone? @relation(fields: [storageZoneId], references: [id], onDelete: SetNull)
  alternateUnits String?
  allergens     String?
  countByWeight Boolean  @default(false)
  lastRestocked DateTime?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  wasteLogs     InventoryWaste[]
  recipeLines   MenuRecipeLine[]
  vendorCatalogItems VendorCatalogItem[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceiptLines  GoodsReceiptLine[]
  invoiceLines       VendorInvoiceLine[]
  lots               InventoryLot[]
  countRouteSteps    CountRouteStep[]
  countLines         InventoryCountLine[]

  @@unique([locationId, barcode])
}

model StorageZone {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name       String
  slug       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  items         InventoryItem[]
  routeSteps    CountRouteStep[]
  countSessions InventoryCountSession[]
  countLines    InventoryCountLine[]
  zoneAssignments CountZoneAssignment[]
  lots          InventoryLot[]

  @@unique([locationId, slug])
  @@index([locationId, sortOrder])
}

model CountRouteStep {
  id              String         @id @default(cuid())
  zoneId          String
  zone            StorageZone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  customLabel     String?
  sortOrder       Int            @default(0)

  @@index([zoneId, sortOrder])
}

model InventoryLot {
  id              String         @id @default(cuid())
  locationId      String
  location        Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  zoneId          String?
  zone            StorageZone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  lotNumber       String?
  quantity        Float
  unit            String
  receivedAt      DateTime       @default(now())
  expiresAt       DateTime?
  createdAt       DateTime       @default(now())

  @@index([locationId, expiresAt])
  @@index([inventoryItemId, receivedAt])
}

model InventoryCountSession {
  id          String       @id @default(cuid())
  locationId  String
  location    Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  zoneId      String?
  zone        StorageZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  sessionType String       @default("ZONE")
  periodMonth DateTime?
  status      String       @default("IN_PROGRESS")
  startedBy   String?
  startedAt   DateTime     @default(now())
  finalizedAt DateTime?
  notes       String?
  createdAt   DateTime     @default(now())

  lines InventoryCountLine[]
  zoneAssignments CountZoneAssignment[]

  @@index([locationId, status])
  @@index([locationId, sessionType, periodMonth])
}

model CountZoneAssignment {
  id            String                @id @default(cuid())
  sessionId     String
  session       InventoryCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  zoneId        String
  zone          StorageZone           @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  staffMemberId String
  staffMember   StaffMember           @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  assignedAt    DateTime              @default(now())

  @@unique([sessionId, zoneId])
  @@index([sessionId])
  @@index([staffMemberId])
}

model InventoryCountLine {
  id              String                @id @default(cuid())
  sessionId       String
  session         InventoryCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inventoryItemId String
