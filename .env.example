DATABASE_URL="file:./dev.db"
# Production: use PostgreSQL (Neon, Supabase, Vercel Postgres), e.g.:
# DATABASE_URL="postgresql://user:pass@host:5432/pinnacle?sslmode=require"
# ALLOW_SQLITE_PRODUCTION="true"  # preview/embed only — not for real customers
# Vercel: `vercel-build` creates prisma/deploy.sqlite and copies it to /tmp at runtime.
# Set AUTH_SECRET in Vercel project settings (required for production sessions).
OPENAI_API_KEY=""
AUTH_SECRET="change-this-to-a-random-secret-in-production"

# Origins allowed to iframe embed routes (/embed and ?embed=mobile|full). Always includes 'self'.
# GitHub Pages (*.github.io) and common localhost doc-preview ports are allowed by default.
# Optional overrides:
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"  # Required in production
# GITHUB_PAGES_ORIGIN="https://youruser.github.io"
# EMBED_FRAME_ANCESTORS="https://youruser.github.io,http://localhost:5500"

# Social media API keys (optional — without these, posts are simulated)
# Live publishing: Facebook, Instagram (Meta), and X only. Other platforms always simulate.
META_ACCESS_TOKEN=""
META_PAGE_ID=""
X_BEARER_TOKEN=""
TIKTOK_ACCESS_TOKEN=""
SNAPCHAT_ACCESS_TOKEN=""
YOUTUBE_ACCESS_TOKEN=""
LINKEDIN_ACCESS_TOKEN=""
PINTEREST_ACCESS_TOKEN=""

# Weather forecast (optional — auto-connects via Open-Meteo when unset)
# IBM Weather Company / Weather.com API key (preferred when available)
WEATHER_COM_API_KEY=""
# OpenWeatherMap fallback
OPENWEATHER_API_KEY=""

# Website analytics (optional — traffic metrics are simulated until GA Data API is wired)
GOOGLE_ANALYTICS_PROPERTY_ID=""

# Automation webhook (Zapier / Make / n8n inbound)
INTEGRATION_WEBHOOK_SECRET=""

# Delivery marketplace menu sync (optional — payloads prepared locally until APIs are wired)
DOORDASH_API_KEY=""
DOORDASH_MERCHANT_ID=""
UBER_EATS_API_KEY=""
UBER_EATS_MERCHANT_ID=""
GRUBHUB_API_KEY=""
GRUBHUB_MERCHANT_ID=""

# --- Payments & billing (optional) ---
# Subscription autopay via Stripe Checkout + Customer Portal
# Test keys: https://dashboard.stripe.com/test/apikeys
# Live keys:  https://dashboard.stripe.com/apikeys (toggle off Test mode)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Production webhook: https://YOUR_APP/api/webhooks/stripe
# Run once: APP_URL=https://YOUR_APP npm run stripe:setup:live
# Events: checkout.session.completed, customer.subscription.*, invoice.payment_failed
# Optional fixed price IDs per plan (otherwise Stripe creates prices dynamically)
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_GROWTH=""
STRIPE_PRICE_PRO=""

# Guest card payments — Stripe Connect (OAuth)
STRIPE_CONNECT_CLIENT_ID=""

# Guest card payments — Square (OAuth)
SQUARE_APPLICATION_ID=""
SQUARE_APPLICATION_SECRET=""
# sandbox | production
SQUARE_ENVIRONMENT="sandbox"

# Support contact shown in Account → Payments & support
SUPPORT_EMAIL="support@pinnacle.app"

# Platform admin (comma-separated emails) — access /admin panel
PLATFORM_ADMIN_EMAILS=""

# Plan trial length (days) when Stripe billing is required in production
PLAN_TRIAL_DAYS="14"
# Set true to allow app access without Stripe autopay (local/staging override)
PLAN_BILLING_OPTIONAL="false"

# App store listings (optional — shown on /download after purchase)
NEXT_PUBLIC_APP_STORE_URL=""
NEXT_PUBLIC_PLAY_STORE_URL=""

# --- Hiring / SMS (optional) ---
# Twilio for text-to-apply and interview reminders
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- Accounting integrations (optional) ---
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
SAGE_CLIENT_ID=""
SAGE_CLIENT_SECRET=""

# --- Vendor EDI (optional) ---
SYSCO_EDI_API_KEY=""
US_FOODS_EDI_API_KEY=""
GORDON_FOOD_SERVICE_EDI_API_KEY=""

# --- Vendor email (optional — credit memo requests & PO transmission) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_SECURE="false"

# --- Reservation platforms (optional) ---
# OpenTable GuestCenter / partner API
OPENTABLE_PARTNER_API_KEY=""
OPENTABLE_CLIENT_ID=""
OPENTABLE_CLIENT_SECRET=""
# Resy, Tock, Yelp Guest Manager
RESY_API_KEY=""
TOCK_API_KEY=""
YELP_FUSION_API_KEY=""
