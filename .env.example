DATABASE_URL="file:./dev.db"
# Vercel: `vercel-build` creates prisma/deploy.sqlite and copies it to /tmp at runtime.
# Set AUTH_SECRET in Vercel project settings (required for production sessions).
OPENAI_API_KEY=""
AUTH_SECRET="change-this-to-a-random-secret-in-production"

# Origins allowed to iframe embed routes (/embed and ?embed=mobile|full). Always includes 'self'.
# GitHub Pages (*.github.io) and common localhost doc-preview ports are allowed by default.
# Optional overrides:
# NEXT_PUBLIC_APP_URL="https://pinnacle-resturant-manager.vercel.app"
# GITHUB_PAGES_ORIGIN="https://youruser.github.io"
# EMBED_FRAME_ANCESTORS="https://youruser.github.io,http://localhost:5500"

# Social media API keys (optional — without these, posts are simulated)
META_ACCESS_TOKEN=""
META_PAGE_ID=""
X_BEARER_TOKEN=""
TIKTOK_ACCESS_TOKEN=""
SNAPCHAT_ACCESS_TOKEN=""
YOUTUBE_ACCESS_TOKEN=""
LINKEDIN_ACCESS_TOKEN=""
PINTEREST_ACCESS_TOKEN=""

# Weather forecast (optional — auto-connects via Open-Meteo when unset)
# IBM Weather Company / Weather.com API key (preferred when available)
WEATHER_COM_API_KEY=""
# OpenWeatherMap fallback
OPENWEATHER_API_KEY=""

# Website analytics (optional — without this, traffic metrics are simulated on sync)
GOOGLE_ANALYTICS_PROPERTY_ID=""

# --- Payments & billing (optional) ---
# Subscription autopay via Stripe Checkout + Customer Portal
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Stripe Dashboard → Webhooks → https://YOUR_APP/api/webhooks/stripe
# Events: checkout.session.completed, customer.subscription.*, invoice.payment_failed
# Optional fixed price IDs per plan (otherwise Stripe creates prices dynamically)
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_GROWTH=""
STRIPE_PRICE_PRO=""

# Guest card payments — Stripe Connect (OAuth)
STRIPE_CONNECT_CLIENT_ID=""

# Guest card payments — Square (OAuth)
SQUARE_APPLICATION_ID=""
SQUARE_APPLICATION_SECRET=""
# sandbox | production
SQUARE_ENVIRONMENT="sandbox"

# Support contact shown in Account → Payments & support
SUPPORT_EMAIL="support@pinnacle.app"

# Platform admin (comma-separated emails) — access /admin panel
PLATFORM_ADMIN_EMAILS=""

# --- Hiring / SMS (optional) ---
# Twilio for text-to-apply and interview reminders
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
